grammar OLC;

/*
|--------------------------------------------------------------------------
| PARSER RULE (mínima)
|--------------------------------------------------------------------------
*/

program
    : statement* EOF
    ;

statement
    : IDENTIFIER
    ;

/*
|--------------------------------------------------------------------------
| IDENTIFICADORES
|--------------------------------------------------------------------------
*/

IDENTIFIER
    : LETTER (LETTER | DIGIT)*
    ;

/*
|--------------------------------------------------------------------------
| FRAGMENTOS
|--------------------------------------------------------------------------
*/

fragment LETTER
    : [_\p{L}]
    ;

fragment DIGIT
    : [0-9]
    ;

/*
|--------------------------------------------------------------------------
| TIPOS ESTÁTICOS (PALABRAS RESERVADAS)
|--------------------------------------------------------------------------
*/

INT32   : 'int32';
FLOAT32 : 'float32';
BOOL    : 'bool';
RUNE    : 'rune';
STRING  : 'string';

TRUE    : 'true';
FALSE   : 'false';

/*
|--------------------------------------------------------------------------
| COMENTARIOS
|--------------------------------------------------------------------------
*/

LINE_COMMENT
    : '//' ~[\r\n]* -> skip
    ;

BLOCK_COMMENT
    : '/*' .*? '*/' -> skip
    ;

/*
|--------------------------------------------------------------------------
| ESPACIOS
|--------------------------------------------------------------------------
*/

WS
    : [ \t\r\n]+ -> skip
    ;